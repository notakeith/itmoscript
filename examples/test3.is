// --- переменные, типы, выражения ---
x = 10
y = 20.5
name = "ITMO"
flag = true
empty = nil
list = [1, 2, 3]
slice1 = name[1:]
slice2 = list[1:2]
slice3 = name[:3]
slice4 = name[:]
slice5 = name[2]

// --- арифметика, логика, сравнение ---
a = x + y * 2 - 4 / 2 % 3 ^ 2
b = not false and true or false
c = (x > 5) and (y <= 100) or (x == 10)
d = x != 15

// --- присваивания всех видов ---
x += 1
y -= 2
x *= 3
y /= 4
// x %= 5
// y ^= 2

// --- if-elseif-else с пустым блоком ---
if x < 5 then
    msg = "low"
else if x == 10 then
    msg = "perfect"
else
    msg = "high"
end if

// --- while с break и continue ---
count = 0
while count < 5
    count += 1
    if count == 3 then
        continue
    else if count == 4 then
        break
    end if
end while

// --- for с range и функцией внутри ---
sum = 0
for i in range(1,5,1)
    sum += i
end for

// --- определение функции ---
add = function(a, b)
    return a + b
end function

// --- вызов функции ---
res = add(3, 4)

// --- функция с пустым телом ---
noop = function() end function

// --- анонимная функция как значение ---
twice = function(f, x)
    return f(f(x))
end function

inc = function(n)
    return n + 1
end function

v = twice(inc, 5)

// --- вложенные вызовы и список аргументов ---
concat = function(a, b, c)
    return a + b + c
end function

s = concat("A", "B", "C")
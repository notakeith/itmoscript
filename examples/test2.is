// Цикл for
sum2 = 0
for x in range(1,5,1)
    sum2 += x
end for

// Анонимная функция
apply_twice = function(f, x)
    return f(f(x))
end function

double = function(n)
    return n * 2
end function

res = apply_twice(double, 5)

// Локальные переменные не доступны снаружи
func_with_inner = function()
    a = 1
    inner = function()
        a = a + 1
        return a
    end function
    return inner()
end function

val = func_with_inner()

